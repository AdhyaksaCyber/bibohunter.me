{
  "name": "ultron-bimbel",
  "version": "1.0.0",
  "description": "Platform bimbingan belajar CPNS modern premium production-ready",
  "type": "module",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wrangler dev --local\"",
    "dev:frontend": "vite",
    "dev:worker": "wrangler dev --local",
    "preview": "vite preview",
    "build": "npm run build:db && npm run build:frontend && npm run build:worker",
    "build:frontend": "vite build",
    "build:worker": "wrangler build",
    "build:db": "drizzle-kit generate:sqlite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "migrate:local": "node scripts/migrate-local.js",
    "seed:local": "node scripts/seed-local.js",
    "db:studio": "drizzle-kit studio",
    "deploy": "npm run build && wrangler deploy",
    "preview:full": "npm run build && vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "@tanstack/react-query": "^5.27.0",
    "@tanstack/react-table": "^8.13.2",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "dompurify": "^3.0.6",
    "drizzle-orm": "^0.29.1",
    "file-type": "^18.5.0",
    "framer-motion": "^10.16.16",
    "hono": "^3.11.7",
    "jose": "^5.1.0",
    "lucide-react": "^0.294.0",
    "mammoth": "^1.6.0",
    "nanoid": "^4.0.2",
    "pdfjs-dist": "^4.0.269",
    "pino": "^8.17.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "sanitize-html": "^2.11.0",
    "terser": "^5.47.1",
    "validator": "^13.11.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231121.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/sanitize-html": "^2.9.5",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "better-sqlite3": "^9.2.2",
    "concurrently": "^8.2.2",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.20.7",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wrangler": "^3.27.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
